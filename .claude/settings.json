{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/matthieuelie/.claude/hooks/pr-body-no-test-plan.sh'"
          },
          {
            "type": "command",
            "command": "bash '/Users/matthieuelie/.claude/hooks/git-commit-format-check.sh'"
          },
          {
            "type": "command",
            "command": "bash '/Users/matthieuelie/.claude/hooks/block-main-branch-commits.sh'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/matthieuelie/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ponytail@ponytail": true,
    "typescript-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "theme": "dark"
}
