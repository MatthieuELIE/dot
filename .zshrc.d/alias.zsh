# COMMAND SHORTCUTS
alias v='nvim'
alias hurl='hurl --insecure --error-format long'

# OPEN CONFIG FILES
alias vimrc='nvim ~/.vimrc'
alias zshrc='nvim ~/.zshrc'
alias ALIAS='nvim ~/.zshrc.d/alias.zsh'
alias BINDS='nvim ~/.zshrc.d/bindkeys.zsh'
alias ENV='nvim ~/.zshrc.d/env.zsh'
alias FUNC='nvim ~/.zshrc.d/functions.zsh'

# NVIM
alias NC='nvim ~/.config/nvim/'

# WEZTERM
alias wezterm='flatpak run org.wezfurlong.wezterm'
alias WC='cd ~/dotfiles/.config/wezterm/ && nvim'
